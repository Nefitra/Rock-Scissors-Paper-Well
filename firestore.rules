rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Non-financial collections can be read/written by users
    match /users/{userId} {
      allow read, write: if true;
    }
    match /games/{gameId} {
      allow read, write: if true;
    }
    match /challenges/{challengeId} {
      allow read, write: if true;
    }
    match /reports/{reportId} {
      allow read, write: if true;
    }

    // Allow reads and writes to support server-side client SDK writes in sandbox environment
    match /tonDeposits/{depositId} {
      allow read, write: if true;
    }
    match /tonWithdrawals/{withdrawalId} {
      allow read, write: if true;
    }
    match /ledgerTransactions/{txId} {
      allow read, write: if true;
    }
    match /ledgerEntries/{entryId} {
      allow read, write: if true;
    }
    match /tonProcessedTransactions/{txHash} {
      allow read, write: if true;
    }
    match /tonReconciliation/{recId} {
      allow read, write: if true;
    }
    
    // Default fallback rule
    match /{document=**} {
      allow read: if true;
      allow write: if false; // Deny writes to anything else by default
    }
  }
}
